[
  {"id": "closure-smoke-new-decision-tree-human",
   "sandbox": {"fixture": "rust/fixtures/closure/mini-repo"},
   "cwd": "{SANDBOX}",
   "argv": ["new", "decision", "rac/decisions/pinned-choice.md"],
   "expect_exit": 0,
   "normalize": ["mask-ids"],
   "capture": ["rac/**", ".rac/**"]},

  {"id": "closure-smoke-new-requirement-mkdir-json",
   "sandbox": {"fixture": "rust/fixtures/closure/mini-repo",
               "setup": [{"step": "mkdir", "path": "rac/requirements"}]},
   "cwd": "{SANDBOX}",
   "argv": ["new", "requirement", "rac/requirements/pinned-req.md", "--json"],
   "expect_exit": 0,
   "normalize": ["mask-ids"],
   "capture": ["rac/**"]},

  {"id": "closure-smoke-git-pinned-recency-json",
   "sandbox": {"setup": [
     {"step": "write", "path": "corpus/pinned-base.md",
      "content": "# Pinned Base Note\n\nThe pinned base body.\n"},
     {"step": "git", "commits": [
       {"date": "2024-03-05T10:00:00+02:00", "message": "pin: base corpus"},
       {"date": "2024-04-01T09:30:00-05:00", "message": "pin: second note",
        "write": [{"path": "corpus/pinned-second.md",
                   "content": "# Pinned Second Note\n\nThe pinned second body.\n"}]}
     ]},
     {"step": "write", "path": "corpus/pinned-uncommitted.md",
      "content": "# Pinned Uncommitted Note\n\nThe pinned uncommitted body.\n"}
   ]},
   "cwd": "{SANDBOX}",
   "argv": ["find", "pinned", "corpus", "--json"],
   "expect_exit": 0,
   "normalize": ["mask-json-field:recency.age_days"]},

  {"id": "closure-smoke-setup-chmod-mode-compare",
   "sandbox": {"fixture": "rust/fixtures/closure/mini-repo",
               "setup": [
                 {"step": "write", "path": "hooks/post-edit.sh",
                  "content": "#!/bin/sh\nexit 0\n"},
                 {"step": "chmod-exec", "path": "hooks/post-edit.sh"}
               ]},
   "cwd": "{SANDBOX}",
   "argv": ["validate", "rac"],
   "expect_exit": 0,
   "capture": ["hooks/*"],
   "compare_file_mode": true},

  {"id": "closure-smoke-stdin-text-json",
   "argv": ["validate", "-", "--json"],
   "stdin_text": "# Stdin Smoke\n\n## Problem\n\nProve the literal stdin feed.\n\n## Requirements\n\n[REQ-001] The harness SHALL feed literal stdin text to both engines.\n",
   "expect_exit": 0},

  {"id": "closure-smoke-mask-json-field-export",
   "argv": ["export", "tests/fixtures/export", "--json"],
   "expect_exit": 0,
   "normalize": ["mask-json-field:corpus.rac_version"]},

  {"id": "closure-smoke-sandbox-path-mask",
   "sandbox": {"setup": [{"step": "copy-tree",
                          "from": "rust/fixtures/closure/mini-repo/rac",
                          "to": "corpus"}]},
   "argv": ["validate", "{SANDBOX}/corpus"],
   "expect_exit": 0,
   "normalize": ["mask-sandbox-path"]},

  {"id": "diff-human",
   "argv": ["diff", "rust/fixtures/closure/diff/old.md", "rust/fixtures/closure/diff/new.md"],
   "expect_exit": 0},
  {"id": "diff-json",
   "argv": ["diff", "rust/fixtures/closure/diff/old.md", "rust/fixtures/closure/diff/new.md", "--json"],
   "expect_exit": 0},
  {"id": "diff-same-human",
   "argv": ["diff", "rust/fixtures/closure/diff/old.md", "rust/fixtures/closure/diff/old.md"],
   "expect_exit": 0},
  {"id": "diff-same-json",
   "argv": ["diff", "rust/fixtures/closure/diff/old.md", "rust/fixtures/closure/diff/old.md", "--json"],
   "expect_exit": 0},
  {"id": "diff-txt-extension-human",
   "argv": ["diff", "rust/fixtures/closure/diff/old.txt", "rust/fixtures/closure/diff/new.txt"],
   "expect_exit": 0},
  {"id": "diff-err-missing-positional",
   "argv": ["diff", "rust/fixtures/closure/diff/old.md"],
   "expect_exit": 2, "expect_nonzero_ok": true},
  {"id": "diff-err-old-not-found",
   "argv": ["diff", "rust/fixtures/closure/diff/nope.md", "rust/fixtures/closure/diff/new.md"],
   "expect_exit": 2, "expect_nonzero_ok": true},
  {"id": "diff-err-new-not-found",
   "argv": ["diff", "rust/fixtures/closure/diff/old.md", "rust/fixtures/closure/diff/nope.md"],
   "expect_exit": 2, "expect_nonzero_ok": true},
  {"id": "diff-err-dir-positional",
   "argv": ["diff", "rust/fixtures/closure/diff", "rust/fixtures/closure/diff/new.md"],
   "expect_exit": 2, "expect_nonzero_ok": true},
  {"id": "diff-err-stdin-dash",
   "argv": ["diff", "-", "rust/fixtures/closure/diff/new.md"],
   "expect_exit": 2, "expect_nonzero_ok": true},
  {"id": "diff-err-extra-positional",
   "argv": ["diff", "rust/fixtures/closure/diff/old.md", "rust/fixtures/closure/diff/new.md", "extra.md"],
   "expect_exit": 2, "expect_nonzero_ok": true},

  {"id": "inspect-req-human",
   "argv": ["inspect", "rust/fixtures/closure/inspect/req.md"],
   "expect_exit": 0},
  {"id": "inspect-req-json",
   "argv": ["inspect", "rust/fixtures/closure/inspect/req.md", "--json"],
   "expect_exit": 0},
  {"id": "inspect-req-verbose",
   "argv": ["inspect", "rust/fixtures/closure/inspect/req.md", "--verbose"],
   "expect_exit": 0},
  {"id": "inspect-decision-human",
   "argv": ["inspect", "rust/fixtures/closure/inspect/decision.md"],
   "expect_exit": 0},
  {"id": "inspect-decision-json",
   "argv": ["inspect", "rust/fixtures/closure/inspect/decision.md", "--json"],
   "expect_exit": 0},
  {"id": "inspect-unknown-human",
   "argv": ["inspect", "rust/fixtures/closure/inspect/unknown.md"],
   "expect_exit": 0},
  {"id": "inspect-unknown-verbose",
   "argv": ["inspect", "rust/fixtures/closure/inspect/unknown.md", "--verbose"],
   "expect_exit": 0},
  {"id": "inspect-dir-human",
   "argv": ["inspect", "rust/fixtures/closure/inspect/corpus"],
   "expect_exit": 0},
  {"id": "inspect-dir-json",
   "argv": ["inspect", "rust/fixtures/closure/inspect/corpus", "--json"],
   "expect_exit": 0},
  {"id": "inspect-dir-toplevel-json",
   "argv": ["inspect", "rust/fixtures/closure/inspect/corpus", "--top-level", "--json"],
   "expect_exit": 0},
  {"id": "inspect-stdin-human",
   "argv": ["inspect", "-"],
   "stdin_file": "rust/fixtures/closure/inspect/req.md",
   "expect_exit": 0},
  {"id": "inspect-verbose-json-precedence",
   "argv": ["inspect", "rust/fixtures/closure/inspect/req.md", "--verbose", "--json"],
   "expect_exit": 0},
  {"id": "inspect-emptydir-human",
   "sandbox": {"setup": [{"step": "mkdir", "path": "emptydir"}]},
   "argv": ["inspect", "{SANDBOX}/emptydir"],
   "expect_exit": 0},
  {"id": "inspect-err-not-found",
   "argv": ["inspect", "rust/fixtures/closure/inspect/nope.md"],
   "expect_exit": 2, "expect_nonzero_ok": true},
  {"id": "inspect-err-extension",
   "argv": ["inspect", "rust/fixtures/closure/inspect/notes.txt"],
   "expect_exit": 2, "expect_nonzero_ok": true},

  {"id": "improve-req-human",
   "argv": ["improve", "rust/fixtures/closure/inspect/req.md"],
   "expect_exit": 0},
  {"id": "improve-req-json",
   "argv": ["improve", "rust/fixtures/closure/inspect/req.md", "--json"],
   "expect_exit": 0},
  {"id": "improve-req-template",
   "argv": ["improve", "rust/fixtures/closure/inspect/req.md", "--template"],
   "expect_exit": 0},
  {"id": "improve-decision-human",
   "argv": ["improve", "rust/fixtures/closure/inspect/decision.md"],
   "expect_exit": 0},
  {"id": "improve-roadmap-complete-human",
   "argv": ["improve", "rust/fixtures/closure/improve/roadmap-complete.md"],
   "expect_exit": 0},
  {"id": "improve-roadmap-complete-template",
   "argv": ["improve", "rust/fixtures/closure/improve/roadmap-complete.md", "--template"],
   "expect_exit": 0},
  {"id": "improve-unknown-human",
   "argv": ["improve", "rust/fixtures/closure/inspect/unknown.md"],
   "expect_exit": 0},
  {"id": "improve-unknown-json",
   "argv": ["improve", "rust/fixtures/closure/inspect/unknown.md", "--json"],
   "expect_exit": 0},
  {"id": "improve-unknown-template",
   "argv": ["improve", "rust/fixtures/closure/inspect/unknown.md", "--template"],
   "expect_exit": 0},
  {"id": "improve-stdin-human",
   "argv": ["improve", "-"],
   "stdin_file": "rust/fixtures/closure/inspect/req.md",
   "expect_exit": 0},
  {"id": "improve-err-mutex",
   "argv": ["improve", "rust/fixtures/closure/inspect/req.md", "--json", "--template"],
   "expect_exit": 2, "expect_nonzero_ok": true},
  {"id": "improve-err-not-found",
   "argv": ["improve", "rust/fixtures/closure/improve/nope.md"],
   "expect_exit": 2, "expect_nonzero_ok": true},
  {"id": "improve-err-extension",
   "argv": ["improve", "rust/fixtures/closure/inspect/notes.txt"],
   "expect_exit": 2, "expect_nonzero_ok": true}
]
